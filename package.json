{
    "name": "cmm-language-support",
    "displayName": "CMM Language Support",
    "description": "Adds syntax highlighting for CMM files.",
    "version": "0.0.1",
    "publisher": "cfaber-ampere",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "cmm",
        "trace32",
        "debugger",
        "syntax",
        "language"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/cfaber-ampere/cmm-language-support.git"
    },
    "contributes": {
        "languages": [
            {
                "id": "cmm",
                "aliases": [
                    "CMM",
                    "cmm"
                ],
                "extensions": [
                    ".cmm"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "cmm",
                "scopeName": "source.cmm",
                "path": "./syntaxes/cmm.tmLanguage.json"
            }
        ]
    }
}